# AdCtira灯塔 面板环境配置
# 复制此文件为 .env 后修改配置

# ===== 面板基础配置 =====

# 面板端口
PANEL_PORT=8888

# 面板语言 (zh_CN/en_US)
PANEL_LANG=zh_CN

# 面板主题 (default/dark)
PANEL_THEME=default

# Debug 模式 (true/false)
PANEL_DEBUG=false

# ===== 安全配置 =====

# 管理员密码最小长度
SECURITY_PASSWORD_MIN_LENGTH=8

# 是否强制密码包含特殊字符
SECURITY_PASSWORD_SPECIAL_CHARS=true

# 登录失败锁定次数
SECURITY_LOGIN_MAX_ATTEMPTS=5

# 登录失败锁定时间(分钟)
SECURITY_LOGIN_LOCK_MINUTES=30

# 是否启用 2FA 双因素认证
SECURITY_ENABLE_2FA=false

# 会话超时时间(分钟)
SESSION_TIMEOUT=60

# ===== Webhook 配置 =====

# Webhook 认证 Token (用于支付回调等服务)
WEBHOOK_AUTH_TOKEN=change_this_to_a_random_token

# ===== 数据库配置 =====

# 数据库类型 (sqlite/mysql)
DB_TYPE=sqlite

# MySQL 配置（DB_TYPE=mysql 时生效）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=adcitra_panel

# ===== Redis 配置 =====

# Redis 主机 (留空表示不启用)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 备份配置 =====

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 云存储备份 (s3/oss/cos/none)
BACKUP_CLOUD_TYPE=none

# S3 (阿里云OSS/亚马逊S3/MinIO)
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=

# ===== 日志配置 =====

# 日志级别
LOG_LEVEL=info

# 日志保留天数
LOG_RETENTION_DAYS=30
