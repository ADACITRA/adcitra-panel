# Docker 构建忽略文件
# 忽略版本控制
.git/
.gitignore
.gitattributes

# 忽略临时文件
__pycache__/
*.pyc
*.pyo
*.swp
*.swo
*~

# 忽略运行时数据
data/default.db
data/system.db
data/cache/
logs/
*.log

# 忽略 Docker 相关
.docker/
docker-compose.override.yml

# 忽略开发文件
README.md
SECURITY.md
.git.sh
update.sh
runconfig.py

# 忽略系统文件
.DS_Store
Thumbs.db
